# Frontend -> API base URL
VITE_API_URL=http://localhost:4000/api

# API portu
PORT=4000

# API admin şifresi (ilk kurulum/fallback)
# Not: İlk başarılı şifre değişiminden sonra hash server/db.json içinde saklanır.
ADMIN_PASSWORD=change_me

# CORS (prod'da frontend domain'inizi yazın, örn: https://menu.example.com)
CORS_ORIGIN=*

# Admin login rate limit
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10

# Oturum süresi (saat)
SESSION_TTL_HOURS=24
